generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Person {
  id                  String       @id @default(cuid())
  name                String       @unique
  role                String
  ideasSubmitted      Idea[]       @relation("IdeaSubmittedBy")
  beatsAssigned       Beat[]       @relation("BeatAssignedTo")
  beatsReviewed       Beat[]       @relation("BeatReviewedBy")
  writingAssignments  Assignment[] @relation("AssignmentWriter")
  podAssignments      Assignment[] @relation("AssignmentPodLead")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model Show {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchemaVariable {
  id        String   @id @default(cuid())
  category  String
  value     String
  label     String
  sortOrder Int      @default(0)
  isCore    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, value])
}

model AdminLog {
  id          String   @id @default(cuid())
  action      String
  targetType  String
  targetId    String?
  targetLabel String
  payload     Json
  createdAt   DateTime @default(now())
}

model WorkflowCounter {
  key   String @id
  value Int
}

model Idea {
  id            String     @id @default(cuid())
  code          String     @unique
  show          String
  angle         String
  submittedById String
  submittedBy   Person     @relation("IdeaSubmittedBy", fields: [submittedById], references: [id])
  submittedOn   DateTime
  status        String     @default("NOT_REVIEWED")
  rank          String     @default("UNRANKED")
  setting       String
  opening       String
  tickingClock  String
  stakes        String
  goal          String
  cliffhanger   String
  note          String
  beats         Beat[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Beat {
  id                   String           @id @default(cuid())
  code                 String           @unique
  ideaId               String
  idea                 Idea             @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  title                String
  setting              String
  opening              String
  tickingClock         String
  stakes               String
  goal                 String
  cliffhanger          String
  note                 String
  docLink              String?
  assignedToId         String
  assignedTo           Person           @relation("BeatAssignedTo", fields: [assignedToId], references: [id])
  assignedRole         String
  requestRaisedOn      DateTime
  expectedStartDate    DateTime
  expectedCompleteDate DateTime
  status               String           @default("ASSIGNED")
  submittedOn          DateTime?
  reviewedById         String?
  reviewedBy           Person?          @relation("BeatReviewedBy", fields: [reviewedById], references: [id])
  reviewedOn           DateTime?
  reviewNotes          String?
  assignments          Assignment[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model Assignment {
  id                  String            @id @default(cuid())
  code                String            @unique
  assignmentType      String
  beatId              String?
  beat                Beat?             @relation(fields: [beatId], references: [id], onDelete: SetNull)
  show                String
  angle               String
  writerId            String
  writer              Person            @relation("AssignmentWriter", fields: [writerId], references: [id])
  podLeadId           String
  podLead             Person            @relation("AssignmentPodLead", fields: [podLeadId], references: [id])
  dateAssigned        DateTime
  dateDue             DateTime
  notes               String?
  status              String            @default("ASSIGNED_TO_WRITER")
  submission          String?
  grade               String?
  feedback            String?
  finalOutput         String?
  prodSuffix          String?
  submittedAt         DateTime?
  reviewedAt          DateTime?
  productionReadyAt   DateTime?
  parentAssignmentId  String?
  parentAssignment    Assignment?       @relation("AssignmentRework", fields: [parentAssignmentId], references: [id])
  childAssignments    Assignment[]      @relation("AssignmentRework")
  editCode            String
  codeToRework        String?
  updatedBeats        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}
