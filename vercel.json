{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run prisma:generate && npm run build:client",
  "outputDirectory": "client/dist",
  "regions": ["syd1"],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "node_modules/.prisma/client/**"
    }
  }
}
